// FinPro — Gestor de Finanças Pessoais (multi-usuário)
// Modelo de dados relacional com isolamento por usuário

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIO — dono de todas as finanças (autenticação via NextAuth)
// ============================================================
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  goals        Goal[]
}

// ============================================================
// CONTA — onde o dinheiro fica (dinheiro, banco, cartão)
// ============================================================
model Account {
  id            String        @id @default(cuid())
  name          String
  type          String        @default("cash") // cash | bank | card
  initialBalance Float        @default(0)
  color         String        @default("#6B7280")
  userId        String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[] @relation("AccountTransactions")
  transfersIn   Transaction[] @relation("TransferTo")
  budgets       Budget[]

  @@index([userId])
  @@index([type])
}

// ============================================================
// CATEGORIA — classificação de receitas/despesas
// ============================================================
model Category {
  id        String        @id @default(cuid())
  name      String
  type      String        @default("expense") // income | expense
  color     String        @default("#6B7280")
  icon      String        @default("Circle")
  userId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@index([type])
}

// ============================================================
// TRANSAÇÃO — lançamento financeiro
// ============================================================
model Transaction {
  id          String   @id @default(cuid())
  type        String   @default("expense") // income | expense | transfer
  amount      Float
  description String
  date        DateTime
  accountId   String
  categoryId  String?
  transferToAccountId String?
  userId      String

  account     Account   @relation("AccountTransactions", fields: [accountId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  transferTo  Account?  @relation("TransferTo", fields: [transferToAccountId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([type])
  @@index([date])
}

// ============================================================
// ORÇAMENTO — limite de gasto por categoria/mês
// ============================================================
model Budget {
  id         String   @id @default(cuid())
  amount     Float
  month      Int      // 1-12
  year       Int
  categoryId String
  accountId  String
  userId     String

  category   Category @relation(fields: [categoryId], references: [id])
  account    Account  @relation(fields: [accountId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, month, year, accountId])
  @@index([userId])
  @@index([month, year])
}

// ============================================================
// META — objetivo financeiro com prazo
// ============================================================
model Goal {
  id             String   @id @default(cuid())
  title          String
  targetAmount   Float
  currentAmount  Float    @default(0)
  deadline       DateTime
  color          String   @default("#10B981")
  isCompleted    Boolean  @default(false)
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions  GoalContribution[]
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  amount    Float
  date      DateTime @default(now())
  note      String?

  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}
